{
  "name": "business-frontpage-lead-capture",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "db:generate": "prisma generate",
    "db:migrate": "node --env-file-if-exists=.env scripts/setup-database.mjs",
    "db:push": "node --env-file-if-exists=.env scripts/setup-database.mjs",
    "db:seed": "node --env-file-if-exists=.env scripts/seed-database.mjs",
    "db:reset": "node --env-file-if-exists=.env scripts/setup-database.mjs --reset",
    "auth:hash": "node scripts/hash-admin-password.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
